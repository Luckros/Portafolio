# Copiá este archivo a .env.local y completá con tus valores reales.
# .env.local NUNCA se sube al repo (ver .gitignore).

# API key de https://resend.com — se genera gratis, sin tarjeta, para empezar.
RESEND_API_KEY=

# El email adonde querés que lleguen las consultas del formulario.
CONTACT_TO_EMAIL=hola@tudominio.com
